<li class="list-group-item d-flex justify-content-between align-items-center">
  <span
    ><%= user.name %> (<%= user.email %>) —
    <strong><%= user.user_type %></strong></span
  >
  <div>
    <a
      href="/promoteUser?email=<%= user.email %>"
      class="btn btn-success btn-sm me-1"
      >Promote to Admin</a
    >
    <a href="/demoteUser?email=<%= user.email %>" class="btn btn-danger btn-sm"
      >Demote to User</a
    >
  </div>
</li>
